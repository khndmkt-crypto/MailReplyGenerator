{
  "lm_studio": {
    "url": "http://localhost:1234/v1",
    "model": "openai/gpt-oss-20b",
    "api_key": "lm-studio",
    "timeout": 60
  },
  "ui": {
    "window_width": 800,
    "window_height": 600,
    "font_size": 12
  },
  "generation": {
    "temperature": 0.7,
    "max_tokens": 1000
  },
  "language_detection": {
    "default_language": "auto",
    "fallback_language": "ja"
  }
}
